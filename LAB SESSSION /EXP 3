
from google.colab import files
uploaded = files.upload()

import cv2
from google.colab.patches import cv2_imshow
import os

# Assuming 'uploaded' dictionary is available from previous cell execution
if uploaded:
    image_filename = list(uploaded.keys())[0]
    img = cv2.imread(os.path.join('/content/', image_filename))
else:
    print("No file uploaded. Please upload an image.")
    img = None

if img is not None:
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    edges = cv2.Canny(gray, 100, 200)
    cv2.imwrite('Canny_Edges_3rd.jpg', edges)
    cv2_imshow(edges)
else:
    print("Image could not be loaded. Please check the filename or if a file was uploaded.")
