import cv2
import numpy as np
import matplotlib.pyplot as plt

# Load grayscale image
img = cv2.imread('/content/simple_grayscale_image.jpg', cv2.IMREAD_GRAYSCALE)

if img is None:
    print("Error: Image not found! Please check the path '/content/simple_grayscale_image.jpg' or provide a valid image file.")
else:
    plt.imshow(img, cmap='gray')
    plt.title("Original (256 Levels)")
    plt.axis('off')
    plt.show()

def quantize(image, levels):
    step = 256 // levels
    quantized = (image // step) * step
    return quantized

q16 = quantize(img, 16)   # 4-bit
q8  = quantize(img, 8)    # 3-bit
q4  = quantize(img, 4)    # 2-bit

plt.figure(figsize=(10,8))

plt.subplot(2,2,1)
plt.imshow(img, cmap='gray')
plt.title("Original (256 Levels)")
plt.axis('off')

plt.subplot(2,2,2)
plt.imshow(q16, cmap='gray')
plt.title("16 Levels")
plt.axis('off')

plt.subplot(2,2,3)
plt.imshow(q8, cmap='gray')
plt.title("8 Levels")
plt.axis('off')

plt.subplot(2,2,4)
plt.imshow(q4, cmap='gray')
plt.title("4 Levels")
plt.axis('off')

plt.show()

