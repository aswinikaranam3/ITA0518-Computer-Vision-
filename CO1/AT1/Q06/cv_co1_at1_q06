import cv2
import numpy as np
import matplotlib.pyplot as plt

# Load input image
image = cv2.imread('/content/im.jpg')   # Use your image

if image is None:
    print("Error: Image not found at '/content/im.jpg'!")
else:
    # Convert to RGB
    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)

    plt.imshow(image_rgb)
    plt.title("Input Image")
    plt.axis('off')
    plt.show()

# Convert to grayscale (approx illumination)
if image is not None:
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

    plt.imshow(gray, cmap='gray')
    plt.title("Illumination Component")
    plt.axis('off')
    plt.show()
else:
    print("Cannot convert to grayscale: Image not loaded. Please ensure 'image' variable contains a valid image.")

# Enhance illumination
if 'gray' in locals() and gray is not None:
    enhanced = cv2.equalizeHist(gray)

    plt.imshow(enhanced, cmap='gray')
    plt.title("Enhanced Image")
    plt.axis('off')
    plt.show()
else:
    print("Cannot enhance illumination: Grayscale image 'gray' is not defined or is invalid. Please ensure the image is loaded and converted to grayscale first.")

# Remove noise
if 'enhanced' in locals() and enhanced is not None:
    denoised = cv2.GaussianBlur(enhanced, (5,5), 0)

    plt.imshow(denoised, cmap='gray')
    plt.title("Denoised Image")
    plt.axis('off')
    plt.show()
else:
    print("Cannot remove noise: Enhanced image 'enhanced' is not defined or is invalid. Please ensure the previous steps (loading, grayscale, enhancement) were successful.")

plt.figure(figsize=(10,5))

plt.subplot(1,2,1)
if 'image_rgb' in locals() and image_rgb is not None:
    plt.imshow(image_rgb)
    plt.title("Original")
else:
    plt.text(0.5, 0.5, "Original Image not available", horizontalalignment='center', verticalalignment='center')
    plt.title("Original")
    plt.axis('off')

plt.subplot(1,2,2)
if 'denoised' in locals() and denoised is not None:
    plt.imshow(denoised, cmap='gray')
    plt.title("Improved Image")
else:
    plt.text(0.5, 0.5, "Improved Image not available", horizontalalignment='center', verticalalignment='center')
    plt.title("Improved Image")
    plt.axis('off')

plt.show()

