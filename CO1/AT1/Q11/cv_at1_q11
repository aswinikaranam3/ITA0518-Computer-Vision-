# Step 2: Import libraries
import cv2
import numpy as np
import matplotlib.pyplot as plt

# Step 3: Upload image
from google.colab import files
uploaded = files.upload()

# Step 4: Read image
img_path = list(uploaded.keys())[0]
img = cv2.imread(img_path)
img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

# Step 5: Normalize
img = img / 255.0

# Step 6: Simulate CCD (Low Noise)
ccd_noise = np.random.normal(0, 0.02, img.shape)
ccd_img = np.clip(img + ccd_noise, 0, 1)

# Step 7: Simulate CMOS (High Noise + Pattern Noise)
cmos_noise = np.random.normal(0, 0.05, img.shape)

pattern = np.tile(np.linspace(0, 0.1, img.shape[1]), (img.shape[0], 1))
pattern = np.expand_dims(pattern, axis=2)

cmos_img = np.clip(img + cmos_noise + pattern, 0, 1)

# Step 8: Convert to display format
ccd_img = (ccd_img * 255).astype(np.uint8)
cmos_img = (cmos_img * 255).astype(np.uint8)

# Step 9: Show ONLY two images
plt.figure(figsize=(10,4))

plt.subplot(1,2,1)
plt.imshow(ccd_img)
plt.title("CCD Image")
plt.axis('off')

plt.subplot(1,2,2)
plt.imshow(cmos_img)
plt.title("CMOS Image")
plt.axis('off')

plt.show()
